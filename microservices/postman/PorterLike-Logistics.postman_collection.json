{
  "info": {
    "name": "PorterLike Logistics APIs",
    "description": "End-to-end collection for auth, booking, driver handshake, and tracking APIs through the API gateway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gatewayUrl", "value": "http://localhost:8080" },
    { "key": "userPhone", "value": "9000000001" },
    { "key": "driverPhone", "value": "9000000002" },
    { "key": "userPassword", "value": "password123" },
    { "key": "driverPassword", "value": "password123" },
    { "key": "userToken", "value": "" },
    { "key": "driverToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "idempotencyKey", "value": "booking-request-001" },
    { "key": "bookingId", "value": "" },
    { "key": "driverId", "value": "" },
    { "key": "offerId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{gatewayUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sample User\",\n  \"phone\": \"{{userPhone}}\",\n  \"password\": \"{{userPassword}}\",\n  \"role\": \"USER\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('userToken', json.token || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{gatewayUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{userPhone}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('userToken', json.token || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Driver Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{gatewayUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Driver Account\",\n  \"phone\": \"{{driverPhone}}\",\n  \"password\": \"{{driverPassword}}\",\n  \"role\": \"DRIVER\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('driverToken', json.token || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Driver Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{gatewayUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{driverPhone}}\",\n  \"password\": \"{{driverPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('driverToken', json.token || '');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Driver Ops",
      "item": [
        {
          "name": "Register Driver Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{driverToken}}" }
            ],
            "url": "{{gatewayUrl}}/driver/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Raj Driver\",\n  \"vehicleType\": \"BIKE\",\n  \"vehicleNumber\": \"KA01AB1234\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('driverId', json.id || '');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Set Driver Online",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driverToken}}" }
            ],
            "url": "{{gatewayUrl}}/driver/{{driverId}}/online?online=true"
          }
        },
        {
          "name": "Update Driver Location",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{driverToken}}" }
            ],
            "url": "{{gatewayUrl}}/driver/{{driverId}}/location",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": 12.9716,\n  \"longitude\": 77.5946\n}"
            }
          }
        },
        {
          "name": "Get Nearby Drivers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driverToken}}" }
            ],
            "url": "{{gatewayUrl}}/driver/nearby?vehicleType=BIKE&limit=5"
          }
        },
        {
          "name": "Get Offer Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driverToken}}" }
            ],
            "url": "{{gatewayUrl}}/driver/offers/{{offerId}}"
          }
        },
        {
          "name": "Accept Offer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driverToken}}" }
            ],
            "url": "{{gatewayUrl}}/driver/{{driverId}}/offers/{{offerId}}/accept"
          }
        },
        {
          "name": "Reject Offer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driverToken}}" }
            ],
            "url": "{{gatewayUrl}}/driver/{{driverId}}/offers/{{offerId}}/reject"
          }
        }
      ]
    },
    {
      "name": "Booking Ops",
      "item": [
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('idempotencyKey', `booking-${Date.now()}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('bookingId', json.id || '');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "url": "{{gatewayUrl}}/booking/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickup\": \"Koramangala\",\n  \"dropAddress\": \"Indiranagar\",\n  \"vehicleType\": \"BIKE\"\n}"
            }
          }
        },
        {
          "name": "Get Booking",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{gatewayUrl}}/booking/{{bookingId}}"
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{gatewayUrl}}/booking/cancel/{{bookingId}}"
          }
        }
      ]
    },
    {
      "name": "Tracking Ops",
      "item": [
        {
          "name": "Push Tracking Location",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{driverToken}}" }
            ],
            "url": "{{gatewayUrl}}/tracking/location",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"driverId\": \"{{driverId}}\",\n  \"bookingId\": \"{{bookingId}}\",\n  \"latitude\": 12.972,\n  \"longitude\": 77.595\n}"
            }
          }
        },
        {
          "name": "Get Driver Tracking",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": "{{gatewayUrl}}/tracking/driver/{{driverId}}"
          }
        }
      ]
    }
  ]
}
